{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Rate (req/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(vyapaar_http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ]
    },
    {
      "title": "Error Rate (5xx %)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(vyapaar_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(vyapaar_http_requests_total[5m])) * 100"
        }
      ]
    },
    {
      "title": "Active Celery Workers",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "vyapaar_active_celery_workers"
        }
      ]
    },
    {
      "title": "P95 Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(vyapaar_http_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "title": "OCR Task Success Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(vyapaar_ocr_tasks_total{status=\"success\"}) / sum(vyapaar_ocr_tasks_total) * 100"
        }
      ]
    },
    {
      "title": "Invoices Processed Today",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "increase(vyapaar_invoices_processed_total[24h])"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["vyapaarbandhu"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "VyapaarBandhu Production Dashboard",
  "uid": "vyapaar-prod",
  "version": 1
}
