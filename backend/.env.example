# ═══════════════════════════════════════════════════════════════════
# VyapaarBandhu — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG

# ── Database (PostgreSQL 16 — async) ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vyapaar_bandhu
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=7200

# ── JWT (RS256) — generate keys with: ─────────────────────────────
# openssl genrsa -out keys/private.pem 2048
# openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=604800

# ── WhatsApp (Meta Cloud API — free 1000 conversations/month) ─────
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_VERIFY_TOKEN=

# ── OCR (free — local Tesseract + EasyOCR) ────────────────────────
TESSERACT_CMD=tesseract
OCR_CONFIDENCE_THRESHOLD=0.85
OCR_AMBER_THRESHOLD=0.75
OCR_FALLBACK_THRESHOLD=0.50

# ── Classification (free — local HuggingFace models) ──────────────
BART_MODEL_ID=facebook/bart-large-mnli
INDICBERT_MODEL_ID=meet136/indicbert-gst-classifier
MODELS_CACHE_DIR=./models_cache

# ── S3-compatible storage (MinIO local / Cloudflare R2 prod) ──────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_INVOICES=vyapaar-invoices
S3_BUCKET_EXPORTS=vyapaar-exports
S3_REGION=ap-south-1

# ── Celery ─────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Error tracking (GlitchTip — self-hosted Sentry alternative) ───
SENTRY_DSN=

# ── Security ───────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MIN_PASSWORD_LENGTH=12
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Compliance ─────────────────────────────────────────────────────
ANOMALY_THRESHOLD_MULTIPLIER=2.5

# ── DPDP Act 2023 ─────────────────────────────────────────────────
PRIVACY_POLICY_URL=https://vyapaarbandhu.app/privacy
CONSENT_VERSION=v1.0
